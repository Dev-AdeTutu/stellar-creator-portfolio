#!/usr/bin/env sh

MAX_SIZE=10485760 # 10MB

# Use a temporary file to store the list of changed files
TMP_FILE=$(mktemp)
git diff --cached --name-only --diff-filter=ACM > "$TMP_FILE"

HAS_ERROR=0

while IFS= read -r file; do
  if [ -f "$file" ]; then
    size=$(wc -c < "$file" 2>/dev/null || echo 0)
    if [ "$size" -gt "$MAX_SIZE" ]; then
      echo "🚨 Error: File '$file' is too large! ($size bytes)"
      echo "Maximum allowed commit size per file is 10MB."
      echo "Please remove it from your commit."
      HAS_ERROR=1
    fi
  fi
done < "$TMP_FILE"

rm -f "$TMP_FILE"

if [ "$HAS_ERROR" -eq 1 ]; then
  exit 1
fi
